{
  "name": "gview-backend",
  "version": "1.0.0",
  "description": "Gview API - backend Express para plataforma de demos de jogos",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:audit": "vitest run --reporter=default --reporter=json --outputFile=test-audit-report.json",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "supertest": "^6.3.3",
    "vitest": "^1.0.0"
  },
  "vitest": {
    "environment": "node",
    "globals": true,
    "testTimeout": 15000
  }
}