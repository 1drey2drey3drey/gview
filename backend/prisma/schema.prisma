// Gview — Schema Prisma
// Banco: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  DEVELOPER
  ADMIN
}

enum GameStatus {
  FEATURED
  AVAILABLE
  COMING_SOON
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(PLAYER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  wishlist     Wishlist[]
  reviews      Review[]
}

model Game {
  id               String     @id @default(uuid())
  title            String
  slug             String     @unique
  shortDescription String
  fullDescription  String?
  coverUrl         String?
  trailerUrl       String?
  demoUrl          String?
  status           GameStatus @default(AVAILABLE)
  genre            String?
  studioName       String?
  launchWindow     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  wishlist         Wishlist[]
  reviews          Review[]
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Submission {
  id                   String           @id @default(uuid())
  gameTitle            String
  projectUrl           String?
  description          String
  launchPlans          String?
  targetPlatforms      String?
  launchDateRange      String?
  demoLink             String?
  nextFestParticipation Boolean         @default(false)
  heardAbout           String?
  additionalInfo       String?
  contactRole          String?
  contactEmail         String
  studioName           String?
  attachmentUrl        String?
  reviewStatus         SubmissionStatus @default(PENDING)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}
